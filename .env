# =============================================================================
# QuantaAlpha environment configuration
# =============================================================================

# =============================================================================
# Paths (core: adjust these for your environment)
# =============================================================================

# Qlib data directory (path after unpacking cn_data.zip; must contain calendars/, features/, instruments)
QLIB_DATA_DIR=./data/qlib/cn_data

# Output root (all results, cache, logs under this directory)
DATA_RESULTS_DIR=./data/results

# =============================================================================
# Qlib
# =============================================================================
QLIB_PROVIDER_URI=./data/qlib/cn_data
CONDA_ENV_NAME=quantaalpha
CONDA_DEFAULT_ENV=quantaalpha

# =============================================================================
# LLM API
# =============================================================================
OPENAI_API_KEY=ark-1eddd70f-f003-4d27-b684-cf0773fe83e2-7fd39
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3

# Models
REASONING_MODEL=glm-5.2
CHAT_MODEL=glm-5.2

# =============================================================================
# Global (usually no need to change)
# =============================================================================
USE_LOCAL=True
MAX_RETRY=5
RETRY_WAIT_SECONDS=5
FACTOR_MINING_TIMEOUT=999999
CHAT_MAX_TOKENS=160000
CHAT_TEMPERATURE=0.7

# MLflow (required for Qlib workflow on MLflow 3.x)
MLFLOW_ALLOW_FILE_STORE=true
